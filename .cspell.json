{
  "version": "0.2",
  "language": "en,uk,ru-ru,nitra",
  "ignorePaths": [
    "**/node_modules/**",
    "**/vscode-extension/**",
    "**/.git/**",
    ".vscode",
    "report",
    "*.svg",
    "**/k8s/**/*.yaml",
    "docs/adr/**"
  ],
  "import": [
    "@nitra/cspell-dict/cspell-ext.json"
  ],
  "words": [
    "nitra",
    "unstub",
    "поза",
    "робочими",
    "годинами"
  ],
  "useGitignore": true,
  "gitignoreRoot": "."
}
